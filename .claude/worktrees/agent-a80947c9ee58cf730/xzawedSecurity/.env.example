ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
REDIS_URL=redis://localhost:6379
PORT=3008
MODE=local
WORKSPACE_ROOT=f:/DEVELOPMENT/SOURCE
# SECURITY_SESSION_ID: Redis stream session ID to consume from.
# Defaults to 'default' if not set. Override to isolate multiple security
# service instances consuming from different manager:to-security:<sessionId> streams.
SECURITY_SESSION_ID=default
