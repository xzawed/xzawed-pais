{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/mock-guard.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/branch-check.mjs"
          }
        ]
      }
    ]
  }
}
