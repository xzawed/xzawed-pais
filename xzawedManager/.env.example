# Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Redis
REDIS_URL=redis://localhost:6379

# 서버
PORT=3001
MODE=local

# ── 프리미엄 프로필 프리셋 (G1 · 권장) ─────────────────────────────────────────
# PAIS_PROFILE 하나로 검증된 스택을 켠다 — 아래 Task Manager/검증 플래그를 개별 조립할
# 필요가 없다(개별 env가 프로필을 override). 미지 프로필은 기동 시 명확히 거부.
#   autonomous → TASK_MANAGER_ENABLED·MANAGER_DECOMPOSE_ENABLED·MANAGER_TASK_WORKER·
#                MANAGER_WP_VERIFY=true + MANAGER_LEASE_VISIBILITY_MS=600000 +
#                비용 캡 기본-on(MANAGER_BUDGET_PER_WORKFLOW_USD=5·DAILY=50)
#   ⚠️ SERVICE_JWT_SECRET(≥32자)·DATABASE_URL 필수 — 없으면 기동 거부(무인증/미배선 무음 강등 방지).
#   ⚠️ 고급 verify 채널(conformance/impact/property/mutation/security)·decision/oracle/risk
#      체인은 opt-in(사람 시드 오라클/golden·risk 승인이 있어야 의미 — 기본 on이면 skip/차단).
# PAIS_PROFILE=autonomous

# 선택적 — 운영 환경 전용
# SERVICE_JWT_SECRET=your-jwt-secret   # 설정 시 /api/** 엔드포인트 JWT 보호 활성화
# DATABASE_URL=postgresql://localhost:5432/manager   # 설정 시 세션·도메인 지식(위키) 영속화 (미설정 시 인메모리)
# Docker Compose에서는 docker-compose.yml의 manager 서비스가 공유 postgres로 자동 주입:
#   DATABASE_URL=postgres://xzawed:${POSTGRES_PASSWORD}@postgres:5432/xzawed_orchestrator

# GitHub (Orchestrator가 세션별로 주입 — 직접 설정도 가능)
# GITHUB_TOKEN=

# 승인 게이트 fail-safe (기본 true)
# 파싱 불가·미지 승인 응답을 자동 승인하지 않고 사람 재검토로 에스컬레이션한다(무음 통과 금지).
# 'false'로 두면 레거시 fail-open(파싱 불가→자동 승인) 동작으로 복원.
# MANAGER_GATE_FAILSAFE=true
# MANAGER_MAX_GATE_REASKS=3     # needs_human(재검토 요청) 최대 횟수, 초과 시 세션 중단(에스컬레이션)

# 세션 이벤트소싱 (기본 false — 인메모리 폴백)
# true면 Postgres append-only 이벤트 로그를 진실원천으로 사용(DATABASE_URL 필요), 크래시 후 replay 복원.
# EVENT_SOURCED_SESSION=false
# MANAGER_OUTBOX_POLL_MS=500    # 아웃박스 릴레이 폴링 주기(ms)

# Task Manager / 실행 워커 / 검증 (전부 기본 false·가역, 전제는 사다리식으로 쌓인다)
# TASK_MANAGER_ENABLED=false      # Supervisor 배선(decomposition→dispatch·lease sweep·completion→re-dispatch). 전제: DATABASE_URL
# MANAGER_TASK_WORKER=false       # 실행 워커 — dispatch된 WP를 owningRole 에이전트로 자율 실행. 전제: TASK_MANAGER_ENABLED+DATABASE_URL
# MANAGER_WP_VERIFY=false         # 워커 검증 게이트 — 완료 발행 전 fail-closed 실 검증(결과-근거 판정+파생 빌드·테스트 재실행). 전제: MANAGER_TASK_WORKER
# MANAGER_WP_CONFORMANCE=false    # Oracle conformance — develop_code WP를 사람 승인 GWT로 검증(독립 author→Tester 실행). 전제: MANAGER_WP_VERIFY+OracleRepo(MANAGER_ORACLE_DOR||MANAGER_ORACLE_DRAFT)
# MANAGER_DECISION_ROUTING=false  # P6 사람 결정 라우팅 — fix_reverify 결정을 소비해 escalated WP를 재진입(reopenLease→dispatch_signal). 결정 제출 라우트는 authHook 있을 때만 등록. 전제: MANAGER_DECISION_BRIEF+DATABASE_URL
# MANAGER_WP_SECURITY=false       # security 채널(4d) — develop_code WP 산출물에 결정론 SAST(static+npm audit) 실행→source∈{static,deps}∧severity≥floor면 차단(LLM findings 제외·N6). oracle 미소비. 전제: MANAGER_WP_VERIFY
# MANAGER_WP_SECURITY_MIN_SEVERITY=high  # security 채널 차단 최소 심각도 floor(low/medium/high/critical). 불량값은 high 폴백
# MANAGER_LEASE_VISIBILITY_MS=300000  # lease 가시성 타임아웃(ms). ⚠️ WP_CONFORMANCE on이면 600000↑ 권장(WP당 호출 최대 5단계)·WP_SECURITY on이면 360000↑(호출 1회 추가)
# MANAGER_BUDGET_PER_WORKFLOW_USD=0  # §13 budget 서킷 — 워크플로(세션)당 USD 비용 상한(0=비활성). >0이면 러너가 호출 전 검사·호출 후 누적
# MANAGER_BUDGET_DAILY_USD=0         # §13 budget 서킷 — 일(UTC) 전체 USD 비용 상한(0=비활성). 인메모리·재시작 시 일 카운터 소실
# MANAGER_PROVIDER_CIRCUIT=false     # §13 provider 서킷 — provider(Anthropic) 지속 장애(429/5xx/529·연결/타임아웃) 추적. 연속 실패 임계 도달 시 open→cooldown 동안 fail-fast
# MANAGER_PROVIDER_CIRCUIT_THRESHOLD=5      # 연속 실패 임계(open 트리거)
# MANAGER_PROVIDER_CIRCUIT_COOLDOWN_MS=30000 # open 유지 시간(ms). 경과 후 half_open 1회 probe
# MANAGER_BULKHEAD_GLOBAL=0          # §13 벌크헤드 — 전역 동시 에이전트 RPC 캡(0=무제한). >0이면 7개 RedisAgentHandler에 공유 주입
# MANAGER_BULKHEAD_PER_AGENT=0       # §13 벌크헤드 — 에이전트 종류별 동시 RPC 캡(0=무제한). 캡 도달 시 큐잉(백프레셔·드롭 없음)
# MANAGER_DEGRADED_MODE=             # 선택: 기본 false(P5-3a). true면 운영 강등 모드 추적기(ModeController) 가동 — provider 서킷 open→DEGRADED·budget 일 상한 트립→SAFE 신호를 모드로 집계·전이 로그(관측 전용·enforcement 0). 전제: budget/provider 서킷 중 하나 이상
# MANAGER_MODE_SWEEP_MS=             # 선택: 기본 5000. 강등 모드 신호 폴링 주기 ms
# MANAGER_MODE_STABILITY_WINDOW_MS=  # 선택: 기본 60000. 상향 복귀 히스테리시스 윈도 ms(플래핑 방지·신호 해소 후 이 시간 경과해야 1단계 복귀)
# MANAGER_RISK_CLASSIFY=             # 선택: 기본 false. true면 decompose_request 시 프로젝트 리스크 분류 생성·pending 영속(P2r-3·N6 미승인). 전제: MANAGER_DECOMPOSE_ENABLED+DATABASE_URL
# MANAGER_RISK_ROUTING=              # 선택: 기본 false. true면 risk.approved 소비자(→wp.risk write-back) + 승인 라우트 배선(P2r-4). 전제: TASK_MANAGER_ENABLED+DATABASE_URL
# MANAGER_RISK_DECISION=             # 선택: 기본 false. true면 humanGate.required 리스크 분류를 risk_classification DecisionRequest로 발행 + decision-consumer approve→RiskClassificationRepo.approve(C5). 전제: MANAGER_RISK_CLASSIFY+MANAGER_DECISION_ROUTING+DATABASE_URL

# 모델 라우팅 (D5)
# MANAGER_MODEL_ROUTING=   # 선택: 기본 false. true면 워커가 디스패치 시 승인 modelRouting을 조회해 에이전트 모델 라우팅(off→CLAUDE_MODEL 폴백·D5). 전제: MANAGER_TASK_WORKER+DATABASE_URL+승인 분류
# MANAGER_MODEL_OPUS=      # 선택: 기본 claude-opus-4-8. modelRouting의 opus tier→이 concrete id
# MANAGER_MODEL_SONNET=    # 선택: 기본 claude-sonnet-4-6. modelRouting의 sonnet tier→이 concrete id

# B1 만료 결정 소비자 (결정 EXPIRED 폐루프)
# MANAGER_DECISION_REESCALATE_MAX= # 선택: 기본 1. decision.expired 소비 시 만료 blocking 결정을 바운드 재에스컬레이션하는 최대 횟수(상한 소진 시 warn 로그 종단). MANAGER_DECISION_EXPIRY 전제
