REDIS_URL=redis://localhost:6379
PORT=3007
MODE=local
WORKSPACE_ROOT=f:/DEVELOPMENT/SOURCE
MAX_WATCHERS=10
DEBOUNCE_MS=300
# WATCHER_SESSION_ID: Redis stream key suffix for this instance.
# Each watcher instance must use a unique value to avoid multiple instances
# sharing the same stream key (manager:to-watcher:{WATCHER_SESSION_ID}),
# which would cause message-splitting between instances.
# Defaults to 'default' if unset (only safe for single-instance deployments).
WATCHER_SESSION_ID=default
