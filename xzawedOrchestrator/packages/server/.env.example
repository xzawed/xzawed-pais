# xzawedOrchestrator 환경변수 예시
# .env.example을 복사하여 .env로 사용하세요

# ── 필수 ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...             # CLAUDE_MODE=api 시 필수
REDIS_URL=redis://localhost:6379

# ── 선택 ─────────────────────────────────────────────────────────────────────
PORT=3000
MODE=local                               # local | remote
AUTH=none                                # none | jwt
CLAUDE_MODE=api                          # api | cli | remote
CLAUDE_MODEL=claude-sonnet-4-6

# ── 인증 (AUTH=jwt 시 필수, 각각 32자 이상) ───────────────────────────────────
SERVICE_JWT_SECRET=
USER_JWT_SECRET=

# ── GitHub PAT 암호화 (AES-256-GCM, 64자 hex) ─────────────────────────────
GITHUB_TOKEN_ENCRYPTION_KEY=

# ── 데이터베이스 ────────────────────────────────────────────────────────────
DATABASE_URL=

# ── 서버 연결 ────────────────────────────────────────────────────────────────
MANAGER_URL=http://localhost:3001
WORKSPACE_ROOT=/workspace
SERVE_WEB=false

# ── 세션 WebSocket ───────────────────────────────────────────────────────────
# WS 끊김 후 세션을 정리하기 전 대기하는 grace 기간(ms, 음수·비정수 거부). 이 시간 내
# 재연결(StrictMode 재마운트·serverUrl 변경 등)이면 세션·컨슈머를 유지하고, 재연결이
# 없으면 정리한다. 0이면 즉시 정리(grace 비활성화).
WS_CLEANUP_GRACE_MS=15000

# ── 원격 모드 (CLAUDE_MODE=remote 시) ────────────────────────────────────────
REMOTE_CLI_URL=                          # HTTP 원격 서버 URL
REMOTE_HOST=                             # SSH 호스트
REMOTE_USER=                             # SSH 사용자
REMOTE_KEY_PATH=~/.ssh/id_rsa
