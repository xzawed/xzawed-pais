# ────────────────────────────────
# Anthropic
# ────────────────────────────────

# Claude API 키 (필수)
ANTHROPIC_API_KEY=sk-ant-...

# 사용 모델 (claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-7)
CLAUDE_MODEL=claude-sonnet-4-6

# ────────────────────────────────
# Redis
# ────────────────────────────────

# Redis 연결 URL (필수, 프로덕션: redis://:password@host:6379)
REDIS_URL=redis://localhost:6379

# ────────────────────────────────
# 서버
# ────────────────────────────────

# HTTP 헬스체크 포트 (기본값: 3006)
PORT=3006

# 배포 모드 (local: 내장 서버 + 로컬 Redis | remote: HTTPS + 외부 Redis)
MODE=local

# ────────────────────────────────
# 빌드 보안
# ────────────────────────────────

# 빌드 허용 루트 경로 (필수, 이 경로 외부 빌드 거부)
# Windows: f:/DEVELOPMENT/SOURCE  Linux/macOS: /home/user/workspace
WORKSPACE_ROOT=/path/to/workspace

# 빌드 타임아웃 (밀리초, 기본값: 120000 = 2분)
BUILD_TIMEOUT_MS=120000
